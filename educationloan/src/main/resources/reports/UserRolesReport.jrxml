<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
            http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="UserRolesReport"
        pageWidth="842"
        pageHeight="595"
        orientation="Landscape"
        columnWidth="782"
        leftMargin="30"
        rightMargin="30"
        topMargin="20"
        bottomMargin="20"
        whenNoDataType="AllSectionsNoDetail">

    <!-- ─── Parameters ─────────────────────────────────────────── -->
    <parameter name="REPORT_GENERATED_BY" class="java.lang.String">
        <defaultValueExpression><![CDATA["System"]]></defaultValueExpression>
    </parameter>
    <parameter name="FILTER_ROLE" class="java.lang.String">
        <defaultValueExpression><![CDATA["ALL"]]></defaultValueExpression>
    </parameter>

    <!-- ─── Fields (maps to UserRoleDTO / UserRole entity) ──────── -->
    <!-- UserRole side -->
    <field name="id"          class="java.lang.Long"/>        <!-- UserRole PK       -->
    <field name="assignedBy"  class="java.lang.String"/>
    <field name="assignedAt"  class="java.time.LocalDateTime"/>
    <!-- User side -->
    <field name="userId"      class="java.lang.Long"/>
    <field name="username"    class="java.lang.String"/>
    <field name="firstName"   class="java.lang.String"/>
    <field name="lastName"    class="java.lang.String"/>
    <field name="email"       class="java.lang.String"/>
    <field name="isActive"    class="java.lang.Boolean"/>
    <!-- Role side -->
    <field name="roleId"      class="java.lang.Long"/>
    <field name="roleName"    class="java.lang.String"/>      <!-- RoleEnum.name()   -->

    <!-- ─── Variables ───────────────────────────────────────────── -->
    <variable name="TOTAL_MAPPINGS" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{id}]]></variableExpression>
    </variable>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- TITLE                                                       -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <title>
        <band height="80" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="60" backcolor="#00695C" forecolor="#00695C"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="782" height="38" forecolor="#FFFFFF" backcolor="#00695C" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Education Loan – User Roles Assignment Report]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="38" width="782" height="22" forecolor="#B2DFDB" backcolor="#00695C" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <text><![CDATA[Auth Service  –  /api/v1/user_roles  &  /api/v1/roles]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="62" width="400" height="16" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Generated by: " + $P{REPORT_GENERATED_BY} + "  |  Role filter: " + $P{FILTER_ROLE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="582" y="62" width="200" height="16" forecolor="#555555"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Generated: " + new java.text.SimpleDateFormat("dd-MM-yyyy HH:mm:ss").format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- PAGE HEADER                                                 -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <pageHeader>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="782" height="18" forecolor="#777777"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- COLUMN HEADER                                               -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <columnHeader>
        <band height="26" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="26" backcolor="#00897B" forecolor="#00897B"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="2"   y="0" width="38"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[UR ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="40"  y="0" width="38"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[User ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="78"  y="0" width="88"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Username]]></text>
            </staticText>
            <staticText>
                <reportElement x="166" y="0" width="85"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[First Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="251" y="0" width="85"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Last Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="336" y="0" width="170" height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Email]]></text>
            </staticText>
            <staticText>
                <reportElement x="506" y="0" width="38"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Role ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="544" y="0" width="110" height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Role Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="654" y="0" width="80"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Assigned By]]></text>
            </staticText>
            <staticText>
                <reportElement x="734" y="0" width="46"  height="26" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[Assigned At]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- DETAIL BAND                                                 -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <detail>
        <band height="22" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#FFFFFF" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 != 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#E0F2F1" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <line>
                <reportElement x="0" y="21" width="782" height="1" forecolor="#B2DFDB"/>
            </line>

            <textField>
                <reportElement x="2"   y="0" width="38"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40"  y="0" width="38"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{userId}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="78"  y="0" width="88"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{username}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="166" y="0" width="85"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{firstName}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="251" y="0" width="85"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{lastName}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="336" y="0" width="170" height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="506" y="0" width="38"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{roleId}]]></textFieldExpression>
            </textField>

            <!-- Role name badge coloured per role -->
            <rectangle>
                <reportElement x="546" y="4" width="106" height="14" backcolor="#7B1FA2" mode="Opaque">
                    <printWhenExpression><![CDATA[$F{roleName} != null && $F{roleName}.contains("ADMIN")]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="546" y="4" width="106" height="14" backcolor="#1565C0" mode="Opaque">
                    <printWhenExpression><![CDATA[$F{roleName} != null && $F{roleName}.contains("EMPLOYEE")]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="546" y="4" width="106" height="14" backcolor="#2E7D32" mode="Opaque">
                    <printWhenExpression><![CDATA[$F{roleName} != null && !$F{roleName}.contains("ADMIN") && !$F{roleName}.contains("EMPLOYEE")]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="546" y="4" width="106" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{roleName}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="654" y="0" width="80"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{assignedBy}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="734" y="0" width="46"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{assignedAt} != null
                    ? $F{assignedAt}.format(java.time.format.DateTimeFormatter.ofPattern("dd-MM-yy HH:mm"))
                    : ""]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- SUMMARY                                                     -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <summary>
        <band height="50" splitType="Stretch">
            <line>
                <reportElement x="0" y="2" width="782" height="1" forecolor="#00695C"/>
            </line>
            <rectangle>
                <reportElement x="0" y="8" width="782" height="36" backcolor="#E0F2F1" forecolor="#80CBC4" mode="Opaque"/>
                <graphicElement><pen lineWidth="1.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="20" y="12" width="140" height="14" forecolor="#00695C"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement>
                <text><![CDATA[Total Role Assignments:]]></text>
            </staticText>
            <textField>
                <reportElement x="164" y="12" width="40" height="14" forecolor="#00695C"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_MAPPINGS}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="20" y="28" width="500" height="12" forecolor="#777777"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="7" isItalic="true"/></textElement>
                <text><![CDATA[Role colours: purple = ADMIN  |  blue = EMPLOYEE  |  green = other]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
