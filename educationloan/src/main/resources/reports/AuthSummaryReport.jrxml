<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
            http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="AuthSummaryReport"
        pageWidth="842"
        pageHeight="595"
        orientation="Landscape"
        columnWidth="782"
        leftMargin="30"
        rightMargin="30"
        topMargin="20"
        bottomMargin="20"
        whenNoDataType="AllSectionsNoDetail">

    <!--
     ┌─────────────────────────────────────────────────────────────┐
     │  AuthSummaryReport                                          │
     │  Data source: JRBeanCollectionDataSource<AuthLogDTO>        │
     │                                                             │
     │  AuthLogDTO fields expected:                                │
     │    username        String                                   │
     │    operation       String  (REGISTER | LOGIN | REFRESH)     │
     │    tokenType       String                                   │
     │    accessExpiresAt  String                                  │
     │    refreshExpiresAt String                                  │
     │    accessExpiresInSeconds  Long                             │
     │    refreshExpiresInSeconds Long                             │
     │    timestamp       LocalDateTime  (when the op happened)    │
     │    ipAddress       String  (optional)                       │
     │    success         Boolean                                  │
     └─────────────────────────────────────────────────────────────┘
    -->

    <!-- ─── Parameters ──────────────────────────────────────── -->
    <parameter name="REPORT_GENERATED_BY" class="java.lang.String">
        <defaultValueExpression><![CDATA["System"]]></defaultValueExpression>
    </parameter>
    <parameter name="FROM_DATE" class="java.lang.String">
        <defaultValueExpression><![CDATA["–"]]></defaultValueExpression>
    </parameter>
    <parameter name="TO_DATE" class="java.lang.String">
        <defaultValueExpression><![CDATA["–"]]></defaultValueExpression>
    </parameter>

    <!-- ─── Fields ──────────────────────────────────────────── -->
    <field name="username"                 class="java.lang.String"/>
    <field name="operation"                class="java.lang.String"/>
    <field name="tokenType"                class="java.lang.String"/>
    <field name="accessExpiresAt"          class="java.lang.String"/>
    <field name="refreshExpiresAt"         class="java.lang.String"/>
    <field name="accessExpiresInSeconds"   class="java.lang.Long"/>
    <field name="refreshExpiresInSeconds"  class="java.lang.Long"/>
    <field name="timestamp"                class="java.time.LocalDateTime"/>
    <field name="ipAddress"                class="java.lang.String"/>
    <field name="success"                  class="java.lang.Boolean"/>

    <!-- ─── Variables ───────────────────────────────────────── -->
    <variable name="TOTAL_OPS"      class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{username}]]></variableExpression>
    </variable>
    <variable name="COUNT_REGISTER" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA["REGISTER".equalsIgnoreCase($F{operation}) ? $F{username} : null]]></variableExpression>
    </variable>
    <variable name="COUNT_LOGIN"    class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA["LOGIN".equalsIgnoreCase($F{operation}) ? $F{username} : null]]></variableExpression>
    </variable>
    <variable name="COUNT_REFRESH"  class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA["REFRESH_TOKEN".equalsIgnoreCase($F{operation}) ? $F{username} : null]]></variableExpression>
    </variable>
    <variable name="COUNT_SUCCESS"  class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[Boolean.TRUE.equals($F{success}) ? $F{username} : null]]></variableExpression>
    </variable>
    <variable name="COUNT_FAIL"     class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[!Boolean.TRUE.equals($F{success}) ? $F{username} : null]]></variableExpression>
    </variable>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- TITLE                                                       -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <title>
        <band height="96" splitType="Stretch">
            <!-- Header bar -->
            <rectangle>
                <reportElement x="0" y="0" width="782" height="60" backcolor="#880E4F" forecolor="#880E4F"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="782" height="38" forecolor="#FFFFFF" backcolor="#880E4F" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Education Loan – Auth Operations Report]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="38" width="782" height="22" forecolor="#F8BBD0" backcolor="#880E4F" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <text><![CDATA[Auth Service  –  /api/v1/auth  (register · login · refresh)]]></text>
            </staticText>

            <!-- Meta row -->
            <textField>
                <reportElement x="0" y="62" width="250" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Generated by: " + $P{REPORT_GENERATED_BY}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="250" y="62" width="280" height="14" forecolor="#555555"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Period: " + $P{FROM_DATE} + "  →  " + $P{TO_DATE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="530" y="62" width="252" height="14" forecolor="#555555"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Generated: " + new java.text.SimpleDateFormat("dd-MM-yyyy HH:mm:ss").format(new java.util.Date())]]></textFieldExpression>
            </textField>

            <!-- Divider -->
            <line>
                <reportElement x="0" y="78" width="782" height="1" forecolor="#880E4F"/>
            </line>

            <!-- Legend chips -->
            <rectangle>
                <reportElement x="0" y="82" width="75" height="12" backcolor="#1976D2" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="82" width="75" height="12" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[REGISTER]]></text>
            </staticText>
            <rectangle>
                <reportElement x="80" y="82" width="60" height="12" backcolor="#2E7D32" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="80" y="82" width="60" height="12" forecolor="#FFFFFF" backcolor="#2E7D32" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[LOGIN]]></text>
            </staticText>
            <rectangle>
                <reportElement x="145" y="82" width="80" height="12" backcolor="#E65100" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="145" y="82" width="80" height="12" forecolor="#FFFFFF" backcolor="#E65100" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[REFRESH_TOKEN]]></text>
            </staticText>
            <rectangle>
                <reportElement x="240" y="82" width="55" height="12" backcolor="#2E7D32" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="240" y="82" width="55" height="12" forecolor="#FFFFFF" backcolor="#2E7D32" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[✓ SUCCESS]]></text>
            </staticText>
            <rectangle>
                <reportElement x="300" y="82" width="50" height="12" backcolor="#C62828" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="300" y="82" width="50" height="12" forecolor="#FFFFFF" backcolor="#C62828" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <text><![CDATA[✗ FAILED]]></text>
            </staticText>
        </band>
    </title>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- PAGE HEADER                                                 -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <pageHeader>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="782" height="18" forecolor="#777777"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- COLUMN HEADER                                               -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <columnHeader>
        <band height="26" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="26" backcolor="#AD1457" forecolor="#AD1457"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="2"   y="0" width="100" height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Username]]></text>
            </staticText>
            <staticText>
                <reportElement x="102" y="0" width="105" height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Operation]]></text>
            </staticText>
            <staticText>
                <reportElement x="207" y="0" width="55"  height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
            <staticText>
                <reportElement x="262" y="0" width="65"  height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Token Type]]></text>
            </staticText>
            <staticText>
                <reportElement x="327" y="0" width="140" height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Access Expires At]]></text>
            </staticText>
            <staticText>
                <reportElement x="467" y="0" width="140" height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Refresh Expires At]]></text>
            </staticText>
            <staticText>
                <reportElement x="607" y="0" width="60"  height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Acc Exp(s)]]></text>
            </staticText>
            <staticText>
                <reportElement x="667" y="0" width="60"  height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Ref Exp(s)]]></text>
            </staticText>
            <staticText>
                <reportElement x="727" y="0" width="55"  height="26" forecolor="#FFFFFF" backcolor="#AD1457" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Timestamp]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- DETAIL BAND                                                 -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <detail>
        <band height="22" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#FFFFFF" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 != 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#FCE4EC" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <line>
                <reportElement x="0" y="21" width="782" height="1" forecolor="#F8BBD0"/>
            </line>

            <textField isBlankWhenNull="true">
                <reportElement x="2"   y="0" width="100" height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{username}]]></textFieldExpression>
            </textField>

            <!-- Operation colour badge -->
            <rectangle>
                <reportElement x="104" y="4" width="100" height="14" backcolor="#1976D2" mode="Opaque">
                    <printWhenExpression><![CDATA["REGISTER".equalsIgnoreCase($F{operation})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="104" y="4" width="100" height="14" backcolor="#2E7D32" mode="Opaque">
                    <printWhenExpression><![CDATA["LOGIN".equalsIgnoreCase($F{operation})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="104" y="4" width="100" height="14" backcolor="#E65100" mode="Opaque">
                    <printWhenExpression><![CDATA[$F{operation} != null && !$F{operation}.equalsIgnoreCase("REGISTER") && !$F{operation}.equalsIgnoreCase("LOGIN")]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="104" y="4" width="100" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{operation}]]></textFieldExpression>
            </textField>

            <!-- Status badge -->
            <rectangle>
                <reportElement x="210" y="4" width="50" height="14" backcolor="#2E7D32" mode="Opaque">
                    <printWhenExpression><![CDATA[Boolean.TRUE.equals($F{success})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="210" y="4" width="50" height="14" backcolor="#C62828" mode="Opaque">
                    <printWhenExpression><![CDATA[!Boolean.TRUE.equals($F{success})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="210" y="4" width="50" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[Boolean.TRUE.equals($F{success}) ? "SUCCESS" : "FAILED"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="262" y="0" width="65"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{tokenType}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="327" y="0" width="140" height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{accessExpiresAt}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="467" y="0" width="140" height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{refreshExpiresAt}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="607" y="0" width="60"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{accessExpiresInSeconds}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="667" y="0" width="60"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{refreshExpiresInSeconds}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="727" y="0" width="55"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{timestamp} != null
                    ? $F{timestamp}.format(java.time.format.DateTimeFormatter.ofPattern("dd-MM-yy HH:mm"))
                    : ""]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- SUMMARY                                                     -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <summary>
        <band height="80" splitType="Stretch">
            <line>
                <reportElement x="0" y="2" width="782" height="1" forecolor="#880E4F"/>
            </line>
            <rectangle>
                <reportElement x="0" y="8" width="782" height="66" backcolor="#FCE4EC" forecolor="#F48FB1" mode="Opaque"/>
                <graphicElement><pen lineWidth="1.0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="20" y="12" width="100" height="14" forecolor="#880E4F"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement>
                <text><![CDATA[Auth Summary]]></text>
            </staticText>

            <!-- Row 1: totals -->
            <staticText>
                <reportElement x="20" y="30" width="80" height="12" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Total Ops:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="30" width="35" height="12" forecolor="#880E4F"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_OPS}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="150" y="30" width="60" height="12" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Registers:]]></text>
            </staticText>
            <textField>
                <reportElement x="210" y="30" width="30" height="12" forecolor="#1565C0"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{COUNT_REGISTER}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="255" y="30" width="50" height="12" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Logins:]]></text>
            </staticText>
            <textField>
                <reportElement x="305" y="30" width="30" height="12" forecolor="#1B5E20"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{COUNT_LOGIN}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="30" width="65" height="12" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Token Refresh:]]></text>
            </staticText>
            <textField>
                <reportElement x="415" y="30" width="30" height="12" forecolor="#BF360C"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{COUNT_REFRESH}]]></textFieldExpression>
            </textField>

            <!-- Row 2: success/fail -->
            <staticText>
                <reportElement x="20" y="48" width="65" height="12" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Successful:]]></text>
            </staticText>
            <textField>
                <reportElement x="85" y="48" width="35" height="12" forecolor="#2E7D32"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{COUNT_SUCCESS}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="130" y="48" width="55" height="12" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Failed:]]></text>
            </staticText>
            <textField>
                <reportElement x="185" y="48" width="35" height="12" forecolor="#C62828"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{COUNT_FAIL}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="240" y="48" width="65" height="12" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Success Rate:]]></text>
            </staticText>
            <textField>
                <reportElement x="305" y="48" width="60" height="12" forecolor="#1B5E20"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_OPS} > 0
                    ? String.format("%.1f%%", ($V{COUNT_SUCCESS}.doubleValue() / $V{TOTAL_OPS}) * 100)
                    : "N/A"]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
