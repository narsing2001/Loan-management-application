<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
            http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="UserListReport"
        pageWidth="842"
        pageHeight="595"
        orientation="Landscape"
        columnWidth="782"
        leftMargin="30"
        rightMargin="30"
        topMargin="20"
        bottomMargin="20"
        whenNoDataType="AllSectionsNoDetail">

    <!-- ─── Parameters ─────────────────────────────────────────── -->
    <parameter name="REPORT_GENERATED_BY" class="java.lang.String">
        <defaultValueExpression><![CDATA["System"]]></defaultValueExpression>
    </parameter>
    <parameter name="REPORT_TITLE" class="java.lang.String">
        <defaultValueExpression><![CDATA["Education Loan – User List Report"]]></defaultValueExpression>
    </parameter>

    <!-- ─── Fields (maps to UserDTO / User entity) ──────────────── -->
    <field name="id"              class="java.lang.Long"/>
    <field name="username"        class="java.lang.String"/>
    <field name="firstName"       class="java.lang.String"/>
    <field name="lastName"        class="java.lang.String"/>
    <field name="email"           class="java.lang.String"/>
    <field name="isActive"        class="java.lang.Boolean"/>
    <field name="isEmailVerified" class="java.lang.Boolean"/>
    <field name="createdAt"       class="java.time.LocalDateTime"/>
    <field name="updatedAt"       class="java.time.LocalDateTime"/>

    <!-- ─── Variables ───────────────────────────────────────────── -->
    <variable name="TOTAL_USERS"  class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{id}]]></variableExpression>
    </variable>
    <variable name="ACTIVE_USERS" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[Boolean.TRUE.equals($F{isActive}) ? $F{id} : null]]></variableExpression>
    </variable>
    <variable name="ROW_COLOR"    class="java.awt.Color" calculation="Nothing">
        <variableExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0
            ? new java.awt.Color(240, 248, 255)
            : java.awt.Color.WHITE]]></variableExpression>
    </variable>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- TITLE BAND                                                  -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <title>
        <band height="80" splitType="Stretch">
            <!-- Header bar -->
            <rectangle>
                <reportElement x="0" y="0" width="782" height="60" backcolor="#1565C0" forecolor="#1565C0"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <!-- Report title -->
            <staticText>
                <reportElement x="0" y="0" width="782" height="38" forecolor="#FFFFFF" backcolor="#1565C0" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Education Loan – User List Report]]></text>
            </staticText>
            <!-- Subtitle -->
            <staticText>
                <reportElement x="0" y="38" width="782" height="22" forecolor="#BBDEFB" backcolor="#1565C0" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <text><![CDATA[Auth Service  –  /api/v1/users]]></text>
            </staticText>
            <!-- Generated info -->
            <textField>
                <reportElement x="0" y="62" width="400" height="16" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated by: " + $P{REPORT_GENERATED_BY}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="582" y="62" width="200" height="16" forecolor="#555555"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated: " + new java.text.SimpleDateFormat("dd-MM-yyyy HH:mm:ss").format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- PAGE HEADER                                                 -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <pageHeader>
        <band height="18" splitType="Stretch">
            <textField>
                <reportElement x="0" y="0" width="782" height="18" forecolor="#777777"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- COLUMN HEADER                                               -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <columnHeader>
        <band height="26" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="26" backcolor="#1976D2" forecolor="#1976D2"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="2"   y="0" width="40"  height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[User ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="42"  y="0" width="90"  height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Username]]></text>
            </staticText>
            <staticText>
                <reportElement x="132" y="0" width="90"  height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[First Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="222" y="0" width="90"  height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Last Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="312" y="0" width="190" height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Email]]></text>
            </staticText>
            <staticText>
                <reportElement x="502" y="0" width="55"  height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Active]]></text>
            </staticText>
            <staticText>
                <reportElement x="557" y="0" width="65"  height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Email Verified]]></text>
            </staticText>
            <staticText>
                <reportElement x="622" y="0" width="160" height="26" forecolor="#FFFFFF" backcolor="#1976D2" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <text><![CDATA[Created At (IST)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- DETAIL BAND                                                 -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <detail>
        <band height="22" splitType="Stretch">
            <!-- Alternating row background -->
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#FFFFFF" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 != 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#E3F2FD" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <!-- Bottom border -->
            <line>
                <reportElement x="0" y="21" width="782" height="1" forecolor="#CFD8DC"/>
            </line>

            <textField>
                <reportElement x="2"   y="0" width="40"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="42"  y="0" width="90"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{username}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="132" y="0" width="90"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{firstName}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="222" y="0" width="90"  height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{lastName}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="312" y="0" width="190" height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
            </textField>

            <!-- isActive badge -->
            <rectangle>
                <reportElement x="510" y="4" width="38" height="14" backcolor="#C8E6C9" mode="Opaque">
                    <printWhenExpression><![CDATA[Boolean.TRUE.equals($F{isActive})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.5" lineColor="#81C784"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="510" y="4" width="38" height="14" backcolor="#FFCDD2" mode="Opaque">
                    <printWhenExpression><![CDATA[!Boolean.TRUE.equals($F{isActive})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.5" lineColor="#EF9A9A"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="510" y="4" width="38" height="14"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="7" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[Boolean.TRUE.equals($F{isActive}) ? "YES" : "NO"]]></textFieldExpression>
            </textField>

            <!-- isEmailVerified badge -->
            <rectangle>
                <reportElement x="565" y="4" width="48" height="14" backcolor="#C8E6C9" mode="Opaque">
                    <printWhenExpression><![CDATA[Boolean.TRUE.equals($F{isEmailVerified})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.5" lineColor="#81C784"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="565" y="4" width="48" height="14" backcolor="#FFF9C4" mode="Opaque">
                    <printWhenExpression><![CDATA[!Boolean.TRUE.equals($F{isEmailVerified})]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.5" lineColor="#F9A825"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="565" y="4" width="48" height="14"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="7" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[Boolean.TRUE.equals($F{isEmailVerified}) ? "VERIFIED" : "PENDING"]]></textFieldExpression>
            </textField>

            <!-- createdAt -->
            <textField isBlankWhenNull="true" pattern="dd-MM-yyyy HH:mm">
                <reportElement x="622" y="0" width="160" height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{createdAt} != null
                    ? $F{createdAt}.format(java.time.format.DateTimeFormatter.ofPattern("dd-MM-yyyy HH:mm:ss"))
                    : ""]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- SUMMARY BAND                                               -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <summary>
        <band height="60" splitType="Stretch">
            <line>
                <reportElement x="0" y="2" width="782" height="1" forecolor="#1565C0"/>
            </line>
            <!-- Summary box -->
            <rectangle>
                <reportElement x="0" y="8" width="782" height="44" backcolor="#E8EAF6" forecolor="#C5CAE9" mode="Opaque"/>
                <graphicElement><pen lineWidth="1.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="20" y="12" width="120" height="16" forecolor="#303F9F"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement>
                <text><![CDATA[Report Summary]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="30" width="80" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Total Users:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="30" width="40" height="14" forecolor="#1A237E"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_USERS}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="160" y="30" width="80" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Active Users:]]></text>
            </staticText>
            <textField>
                <reportElement x="240" y="30" width="40" height="14" forecolor="#2E7D32"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{ACTIVE_USERS}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="30" width="80" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8"/></textElement>
                <text><![CDATA[Inactive Users:]]></text>
            </staticText>
            <textField>
                <reportElement x="380" y="30" width="40" height="14" forecolor="#C62828"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_USERS} - $V{ACTIVE_USERS}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
